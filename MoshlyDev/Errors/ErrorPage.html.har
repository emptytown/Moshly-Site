          "content": {
            "size": 0,
            "compression": 0,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Moshly — Tools for the Music Industry</title>\n  <link rel=\"icon\" type=\"image/x-icon\" href=\"/assets/favicon.ico\" />\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap\" rel=\"stylesheet\" />\n  <link rel=\"stylesheet\" href=\"style.css\" />\n</head>\n<body>\n\n  <!-- NAV -->\n  <nav class=\"nav\">\n    <div class=\"nav-inner\">\n      <a href=\"/\" class=\"nav-logo\">\n        <img src=\"assets/Moshly-Main-Logo-1.svg\" alt=\"Moshly\" class=\"nav-logo-img\" />\n        <span class=\"nav-logo-text\">Moshly</span>\n      </a>\n      <div class=\"nav-links\">\n        <a href=\"#apps\" class=\"nav-link\">Apps</a>\n        <a href=\"#roadmap\" class=\"nav-link\">Roadmap</a>\n        <a href=\"app-tour.html\" class=\"nav-link\">Tour</a>\n        <a href=\"pricing.html\" class=\"nav-link\">Pricing</a>\n        <a href=\"/login.html\" class=\"nav-login-btn\" id=\"nav-login-btn\">Log In</a>\n        <a id=\"nav-dash-btn\" href=\"/dashboard.html\" class=\"nav-login-btn u-hidden\">Dashboard →</a>\n      </div>\n      <button class=\"nav-menu-btn\" id=\"navMenuBtn\" aria-label=\"Open navigation menu\" aria-expanded=\"false\" aria-controls=\"mobileNavMenu\">\n        <span class=\"nav-menu-line\"></span>\n        <span class=\"nav-menu-line\"></span>\n        <span class=\"nav-menu-line\"></span>\n      </button>\n    </div>\n    <div class=\"mobile-nav\" id=\"mobileNavMenu\" aria-hidden=\"true\">\n      <a href=\"#apps\" class=\"mobile-nav-link\" onclick=\"closeMobileMenu()\">Apps</a>\n      <a href=\"#roadmap\" class=\"mobile-nav-link\" onclick=\"closeMobileMenu()\">Roadmap</a>\n      <a href=\"app-tour.html\" class=\"mobile-nav-link\" onclick=\"closeMobileMenu()\">Tour</a>\n      <a href=\"pricing.html\" class=\"mobile-nav-link\" onclick=\"closeMobileMenu()\">Pricing</a>\n      <a href=\"/login.html\" class=\"mobile-nav-login-btn\" id=\"mobile-nav-login-btn\" onclick=\"closeMobileMenu()\">Log In</a>\n      <a id=\"mobile-nav-dash-btn\" href=\"/dashboard.html\" class=\"mobile-nav-login-btn u-hidden\" onclick=\"closeMobileMenu()\">Dashboard →</a>\n    </div>\n  </nav>\n\n  <!-- HERO -->\n  <section class=\"hero\">\n    <div class=\"hero-glow hero-glow-1\"></div>\n    <div class=\"hero-glow hero-glow-2\"></div>\n    <div class=\"hero-glow hero-glow-3\"></div>\n    <div class=\"hero-inner\">\n      <div class=\"hero-badge\">\n        <span class=\"badge-dot\"></span>\n        Built for the Music Industry\n      </div>\n      <h1 class=\"hero-title\">\n        Micro-tools.<br />\n        <span class=\"gradient-text\">Maximum impact.</span>\n      </h1>\n      <p class=\"hero-subtitle\">\n        Moshly is a growing suite of sharp, focused apps built for music professionals. No bloat. Just the tool you need, exactly when you need it.\n      </p>\n      <div class=\"hero-actions\">\n        <a href=\"#apps\" class=\"btn-primary\">Explore Apps</a>\n        <a href=\"#roadmap\" class=\"btn-ghost\">See What's Coming</a>\n      </div>\n    </div>\n    <div class=\"hero-scroll-hint\">\n      <span>Scroll</span>\n      <div class=\"scroll-line\"></div>\n    </div>\n  </section>\n\n  <!-- APPS SECTION -->\n  <section class=\"apps-section\" id=\"apps\">\n    <div class=\"section-inner\">\n      <div class=\"section-label\">The Suite</div>\n      <h2 class=\"section-title\">Apps built for <span class=\"gradient-text\">real work</span></h2>\n      <p class=\"section-subtitle\">Each app solves one problem, with simplicity.</p>\n\n      <!-- Vertical route + cards -->\n      <div class=\"apps-route-wrapper\">\n\n        <!-- Vertical route track: node → line → card → line → node → line → card ... -->\n        <div class=\"vr-track\">\n\n          \n          <div class=\"vr-line vr-line--mid\"></div>\n\n          <!-- ── STATION 2: FeeME ── -->\n          <div class=\"vr-node vr-node--mid\" aria-hidden=\"true\">\n            <div class=\"vr-node-glow vr-node-glow--mid\"></div>\n            <div class=\"vr-node-ring vr-node-ring--mid\"></div>\n            <div class=\"vr-node-dot vr-node-dot--mid\"></div>\n          </div>\n          <div class=\"vr-line vr-line--future\"></div>\n\n          <div class=\"app-card app-card--soon reveal\">\n            <div class=\"app-card-top\">\n              <div class=\"app-card-identity\">\n                <div class=\"app-icon-wrap\">\n                  <img src=\"assets/rbapp-logo-icon.svg\" alt=\"RBapp\" class=\"app-icon\" />\n                </div>\n                <div class=\"app-card-meta\">\n                  <h3 class=\"app-name\">FeeME</h3>\n                  <p class=\"app-tagline\">Budget Generator</p>\n                </div>\n              </div>\n              <div class=\"app-status app-status--soon\">\n                <span class=\"status-dot status-dot--soon\"></span>\n                ACTIVE\n              </div>\n            </div>\n            <p class=\"app-desc\">Stop wasting hours on spreadsheets. Generate professional budget PDFs in seconds — perfect for bookings, venues, and tour planning.\n              ✓ Smart input — plug in your rates, equipment, travel. Done, ready to send.</p>\n            <div class=\"app-card-footer\">\n              <div class=\"app-tags\">\n                <span class=\"tag\">Budgeting</span>\n                <span class=\"tag\">PDF Creator</span>\n              </div>\n              <div class=\"app-cta app-cta--disabled\">Notify Me <span class=\"cta-arrow\">→</span></div>\n            </div>\n          </div>\n\n          <div class=\"vr-line vr-line--future\"></div>\n\n          <!-- ── STATION 3: MerchClick ── -->\n          <div class=\"vr-node vr-node--future\" aria-hidden=\"true\">\n            <div class=\"vr-node-ring vr-node-ring--future\"></div>\n            <div class=\"vr-node-dot vr-node-dot--future\"></div>\n          </div>\n          <div class=\"vr-line vr-line--ghost\"></div>\n\n          <div class=\"app-card app-card--soon reveal\">\n            <div class=\"app-card-top\">\n              <div class=\"app-card-identity\">\n                <div class=\"app-icon-wrap\">\n                  <img src=\"assets/merchclick-logo-icon.svg\" alt=\"MerchClick\" class=\"app-icon\" />\n                </div>\n                <div class=\"app-card-meta\">\n                  <h3 class=\"app-name\">MerchClick</h3>\n                  <p class=\"app-tagline\">Click Your Merch In</p>\n                </div>\n              </div>\n              <div class=\"app-status app-status--soon\">\n                <span class=\"status-dot status-dot--soon\"></span>\n                Coming Soon\n              </div>\n            </div>\n            <p class=\"app-desc\">Merch management made effortless. Track inventory, sales, and restocks with a single click — from the stage or the studio to the streets. No spreadsheets, no stress.</p>\n            <div class=\"app-card-footer\">\n              <div class=\"app-tags\">\n                <span class=\"tag\">Merch</span>\n                <span class=\"tag\">Sales</span>\n                <span class=\"tag\">Inventory</span>\n              </div>\n              <div class=\"app-cta app-cta--disabled\">Notify Me <span class=\"cta-arrow\">→</span></div>\n            </div>\n          </div>\n\n          <div class=\"vr-line vr-line--ghost\"></div>\n\n          <!-- ── More to come node ── -->\n          <div class=\"vr-node vr-node--ghost\" aria-hidden=\"true\">\n            <div class=\"vr-node-ring vr-node-ring--ghost\"></div>\n            <span class=\"vr-more-label\">More apps on the way…</span>\n          </div>\n\n        </div><!-- /vr-track -->\n      </div><!-- /apps-route-wrapper -->\n    </div>\n  </section>\n\n  <!-- ROADMAP SECTION -->\n  <section class=\"roadmap-section\" id=\"roadmap\">\n    <div class=\"section-inner\">\n      <div class=\"section-label\">The Journey</div>\n      <h2 class=\"section-title\">Every stop on the <span class=\"gradient-text\">map</span></h2>\n      <p class=\"section-subtitle\">We're building the tools you've always needed. Here's where we're headed.</p>\n\n      <!-- SVG Roadmap Path -->\n      <div class=\"roadmap-container\">\n        <svg class=\"roadmap-svg\" viewBox=\"0 0 1000 260\" preserveAspectRatio=\"xMidYMid meet\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"pathGrad\" x1=\"0\" y1=\"0\" x2=\"1000\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n              <stop offset=\"0%\" stop-color=\"#6B5CFF\"/>\n              <stop offset=\"35%\" stop-color=\"#C026D3\"/>\n              <stop offset=\"65%\" stop-color=\"#6B5CFF\" stop-opacity=\"0.5\"/>\n              <stop offset=\"100%\" stop-color=\"#6B5CFF\" stop-opacity=\"0.12\"/>\n            </linearGradient>\n            <linearGradient id=\"pathGradSolid\" x1=\"0\" y1=\"0\" x2=\"464\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n              <stop offset=\"0%\" stop-color=\"#6B5CFF\"/>\n              <stop offset=\"100%\" stop-color=\"#C026D3\"/>\n            </linearGradient>\n            <linearGradient id=\"ng1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#6B5CFF\"/>\n              <stop offset=\"100%\" stop-color=\"#00E5FF\"/>\n            </linearGradient>\n            <linearGradient id=\"ng2\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#C026D3\"/>\n              <stop offset=\"100%\" stop-color=\"#6B5CFF\"/>\n            </linearGradient>\n            <linearGradient id=\"ng3\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#6B5CFF\"/>\n              <stop offset=\"100%\" stop-color=\"#C026D3\"/>\n            </linearGradient>\n            <filter id=\"glowRM\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"4\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n            <filter id=\"glowSoftRM\" x=\"-100%\" y=\"-100%\" width=\"300%\" height=\"300%\">\n              <feGaussianBlur stdDeviation=\"10\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n          </defs>\n\n          <!-- Dashed background track (full path) -->\n          <path\n            d=\"M 80 130 C 180 130, 230 70, 310 70 C 390 70, 420 130, 464 130 C 544 130, 584 185, 694 185 C 784 185, 834 130, 884 130\"\n            stroke=\"url(#pathGrad)\"\n            stroke-width=\"2\"\n            stroke-dasharray=\"7 5\"\n            opacity=\"0.45\"\n          />\n\n          <!-- Solid active portion (FeeME active) -->\n          <path\n            d=\"M 80 130 C 180 130, 230 70, 310 70 C 390 70, 420 130, 464 130\"\n            stroke=\"url(#pathGradSolid)\"\n            stroke-width=\"2.5\"\n            opacity=\"0.9\"\n          />\n\n          <!-- NODE 1: Moshly.io -->\n          <circle cx=\"80\" cy=\"130\" r=\"26\" fill=\"url(#ng1)\" opacity=\"0.12\" filter=\"url(#glowSoftRM)\"/>\n          <circle cx=\"80\" cy=\"130\" r=\"17\" fill=\"none\" stroke=\"url(#ng1)\" stroke-width=\"1.5\" opacity=\"0.4\"/>\n          <circle cx=\"80\" cy=\"130\" r=\"11\" fill=\"url(#ng1)\" opacity=\"0.75\"/>\n          <circle cx=\"80\" cy=\"130\" r=\"4\" fill=\"#ffffff\" opacity=\"0.9\"/>\n          <text x=\"80\" y=\"104\" text-anchor=\"middle\" fill=\"#ffffff\" font-size=\"12\" font-weight=\"800\" font-family=\"Inter, sans-serif\" letter-spacing=\"-0.3\" filter=\"url(#glowRM)\">Moshly.io</text>\n          <text x=\"80\" y=\"118\" text-anchor=\"middle\" fill=\"#00E5FF\" font-size=\"10\" font-weight=\"600\" font-family=\"Inter, sans-serif\">Active</text>\n\n          <!-- NODE 2: FeeME -->\n          <circle cx=\"464\" cy=\"130\" r=\"26\" fill=\"url(#ng2)\" opacity=\"0.08\" filter=\"url(#glowSoftRM)\"/>\n          <circle cx=\"464\" cy=\"130\" r=\"17\" fill=\"none\" stroke=\"url(#ng2)\" stroke-width=\"1.5\" opacity=\"0.3\"/>\n          <circle cx=\"464\" cy=\"130\" r=\"11\" fill=\"url(#ng2)\" opacity=\"0.55\"/>\n          <circle cx=\"464\" cy=\"130\" r=\"4\" fill=\"#ffffff\" opacity=\"0.65\"/>\n          <text x=\"464\" y=\"104\" text-anchor=\"middle\" fill=\"#A4A7B5\" font-size=\"12\" font-weight=\"700\" font-family=\"Inter, sans-serif\" letter-spacing=\"-0.3\">FeeME</text>\n          <text x=\"464\" y=\"118\" text-anchor=\"middle\" fill=\"#7B7F93\" font-size=\"10\" font-family=\"Inter, sans-serif\">Coming Soon</text>\n\n          <!-- NODE 3: MerchClick -->\n          <circle cx=\"694\" cy=\"185\" r=\"26\" fill=\"url(#ng3)\" opacity=\"0.05\" filter=\"url(#glowSoftRM)\"/>\n          <circle cx=\"694\" cy=\"185\" r=\"17\" fill=\"none\" stroke=\"url(#ng3)\" stroke-width=\"1.5\" opacity=\"0.2\"/>\n          <circle cx=\"694\" cy=\"185\" r=\"11\" fill=\"url(#ng3)\" opacity=\"0.3\"/>\n          <circle cx=\"694\" cy=\"185\" r=\"4\" fill=\"#ffffff\" opacity=\"0.4\"/>\n          <text x=\"694\" y=\"215\" text-anchor=\"middle\" fill=\"#7B7F93\" font-size=\"12\" font-weight=\"700\" font-family=\"Inter, sans-serif\" letter-spacing=\"-0.3\">MerchClick</text>\n          <text x=\"694\" y=\"228\" text-anchor=\"middle\" fill=\"#4A4699\" font-size=\"10\" font-family=\"Inter, sans-serif\">Coming Soon</text>\n\n          <!-- NODE 4: More to come -->\n          <circle cx=\"884\" cy=\"130\" r=\"14\" fill=\"#1B1E2E\" stroke=\"#2D3048\" stroke-width=\"1.5\" stroke-dasharray=\"4 3\" opacity=\"0.6\"/>\n          <text x=\"884\" y=\"134\" text-anchor=\"middle\" fill=\"#4A4699\" font-size=\"14\" font-family=\"Inter, sans-serif\" opacity=\"0.7\">···</text>\n          <text x=\"884\" y=\"112\" text-anchor=\"middle\" fill=\"#4A4699\" font-size=\"10\" font-family=\"Inter, sans-serif\" opacity=\"0.5\">More</text>\n          <text x=\"884\" y=\"124\" text-anchor=\"middle\" fill=\"#4A4699\" font-size=\"10\" font-family=\"Inter, sans-serif\" opacity=\"0.5\">to come</text>\n\n        </svg>\n      </div>\n\n      <!-- Roadmap Station Cards -->\n      <div class=\"roadmap-stations\">\n\n        <div class=\"roadmap-station\">\n          <div class=\"roadmap-station-header\">\n            <div class=\"roadmap-station-num\">01</div>\n            <div class=\"roadmap-badge roadmap-badge--live\">Active</div>\n          </div>\n          <div class=\"roadmap-station-body\">\n            <div class=\"roadmap-station-identity\">\n              <img src=\"assets/Moshly-Main-Logo-1.svg\" alt=\"Moshly\" class=\"roadmap-station-icon\" />\n              <div>\n                <strong class=\"roadmap-station-name\">Moshly.io</strong>\n                <span class=\"roadmap-station-tagline\">Music Industry Ecosystem</span>\n              </div>\n            </div>\n            <p class=\"roadmap-station-desc\">The central hub for all our music industry micro-tools. Moshly.io provides the infrastructure, identity and integration that connects every tool in our suite.</p>\n          </div>\n          <a href=\"#apps\" class=\"roadmap-station-cta\">Explore Apps →</a>\n        </div>\n\n        \n\n        <div class=\"roadmap-station\">\n          <div class=\"roadmap-station-header\">\n            <div class=\"roadmap-station-num\">02</div>\n            <div class=\"roadmap-badge\">Landing</div>\n          </div>\n          <div class=\"roadmap-station-body\">\n            <div class=\"roadmap-station-identity\">\n              <img src=\"assets/rbapp-logo-icon.svg\" alt=\"feeme\" class=\"roadmap-station-icon\" />\n              <div>\n                <strong class=\"roadmap-station-name\">FeeME</strong>\n                <span class=\"roadmap-station-tagline\">Budget Generator</span>\n              </div>\n            </div>\n            <p class=\"roadmap-station-desc\">We set out to solve a problem: make fast budgets in few steps and on the go, because those offers won't stand for long. We wanted a fast input of expenses, perfect visualization and <i>on the fly</i> PDF genetation. Meet FeeME, cash in and enjoy the rest of the day.</p>\n          </div>\n          <a href=\"#notify\" class=\"roadmap-station-cta roadmap-station-cta--muted\">Notify Me →</a>\n        </div>\n\n        <div class=\"roadmap-station\">\n          <div class=\"roadmap-station-header\">\n            <div class=\"roadmap-station-num\">03</div>\n            <div class=\"roadmap-badge\">Coming Soon</div>\n          </div>\n          <div class=\"roadmap-station-body\">\n            <div class=\"roadmap-station-identity\">\n              <img src=\"assets/merchclick-logo-icon.svg\" alt=\"MerchClick\" class=\"roadmap-station-icon\" />\n              <div>\n                <strong class=\"roadmap-station-name\">MerchClick</strong>\n                <span class=\"roadmap-station-tagline\">Click Your Merch In</span>\n              </div>\n            </div>\n            <p class=\"roadmap-station-desc\">Merch management made effortless. Track inventory, sales, and restocks with a single click — from the stage or the studio to the streets. No spreadsheets, no stress.</p>\n          </div>\n          <a href=\"#notify\" class=\"roadmap-station-cta roadmap-station-cta--muted\">Notify Me →</a>\n        </div>\n\n        <div class=\"roadmap-station roadmap-station--mystery\">\n          <div class=\"roadmap-station-header\">\n            <div class=\"roadmap-station-num\">···</div>\n            <div class=\"roadmap-badge roadmap-badge--mystery\">TBA</div>\n          </div>\n          <div class=\"roadmap-station-body\">\n            <div class=\"roadmap-station-identity\">\n              <div class=\"roadmap-station-icon roadmap-station-icon--mystery\">\n                <svg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" fill=\"none\"><circle cx=\"11\" cy=\"11\" r=\"9\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-dasharray=\"3 3\" opacity=\"0.4\"/><path d=\"M11 7v4M11 15h.01\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" opacity=\"0.4\"/></svg>\n              </div>\n              <div>\n                <strong class=\"roadmap-station-name\" style=\"opacity:0.4;\">More to come</strong>\n                <span class=\"roadmap-station-tagline\" style=\"opacity:0.3;\">The suite keeps growing</span>\n              </div>\n            </div>\n            <p class=\"roadmap-station-desc\" style=\"opacity:0.3;\">We keep our roadmap private to stay ahead. Subscribe to Major and be first to know what's next.</p>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </section>\n\n  <!-- CTA / EARLY ACCESS SECTION -->\n  <section class=\"cta-section\" id=\"notify\">\n    <div class=\"cta-glow\"></div>\n    <div class=\"section-inner cta-inner\">\n      <h2 class=\"cta-title\">Stay in the loop.<br /><span class=\"gradient-text\">Be first.</span></h2>\n      <p class=\"cta-subtitle\">Get early access to Moshly apps. No spam, just signal.</p>\n      <form class=\"cta-form cta-form--full\" onsubmit=\"handleEarlyAccess(event)\" id=\"earlyAccessForm\">\n        <div class=\"cta-fields\">\n          <div class=\"cta-field\">\n            <label class=\"cta-label\" for=\"ea-email\">Email</label>\n            <input type=\"email\" id=\"ea-email\" placeholder=\"your@email.com\" class=\"cta-input\" required autocomplete=\"email\" />\n          </div>\n          <div class=\"cta-field\">\n            <label class=\"cta-label\" for=\"ea-phone\">Phone</label>\n            <div class=\"cta-phone-wrap\">\n              <select class=\"cta-dial\" id=\"ea-dial\" required aria-label=\"Country dialing code\">\n                <option value=\"\" disabled selected>Country</option>\n                <option value=\"+355\">🇦🇱 +355 Albania</option>\n                <option value=\"+376\">🇦🇩 +376 Andorra</option>\n                <option value=\"+54\">🇦🇷 +54 Argentina</option>\n                <option value=\"+61\">🇦🇺 +61 Australia</option>\n                <option value=\"+43\">🇦🇹 +43 Austria</option>\n                <option value=\"+32\">🇧🇪 +32 Belgium</option>\n                <option value=\"+55\">🇧🇷 +55 Brazil</option>\n                <option value=\"+1-CA\">🇨🇦 +1 Canada</option>\n                <option value=\"+56\">🇨🇱 +56 Chile</option>\n                <option value=\"+57\">🇨🇴 +57 Colombia</option>\n                <option value=\"+385\">🇭🇷 +385 Croatia</option>\n                <option value=\"+357\">🇨🇾 +357 Cyprus</option>\n                <option value=\"+420\">🇨🇿 +420 Czech Republic</option>\n                <option value=\"+45\">🇩🇰 +45 Denmark</option>\n                <option value=\"+372\">🇪🇪 +372 Estonia</option>\n                <option value=\"+358\">🇫🇮 +358 Finland</option>\n                <option value=\"+33\">🇫🇷 +33 France</option>\n                <option value=\"+49\">🇩🇪 +49 Germany</option>\n                <option value=\"+30\">🇬🇷 +30 Greece</option>\n                <option value=\"+36\">🇭🇺 +36 Hungary</option>\n                <option value=\"+354\">🇮🇸 +354 Iceland</option>\n                <option value=\"+353\">🇮🇪 +353 Ireland</option>\n                <option value=\"+39\">🇮🇹 +39 Italy</option>\n                <option value=\"+81\">🇯🇵 +81 Japan</option>\n                <option value=\"+371\">🇱🇻 +371 Latvia</option>\n                <option value=\"+423\">🇱🇮 +423 Liechtenstein</option>\n                <option value=\"+370\">🇱🇹 +370 Lithuania</option>\n                <option value=\"+352\">🇱🇺 +352 Luxembourg</option>\n                <option value=\"+356\">🇲🇹 +356 Malta</option>\n                <option value=\"+52\">🇲🇽 +52 Mexico</option>\n                <option value=\"+377\">🇲🇨 +377 Monaco</option>\n                <option value=\"+31\">🇳🇱 +31 Netherlands</option>\n                <option value=\"+64\">🇳🇿 +64 New Zealand</option>\n                <option value=\"+47\">🇳🇴 +47 Norway</option>\n                <option value=\"+48\">🇵🇱 +48 Poland</option>\n                <option value=\"+351\">🇵🇹 +351 Portugal</option>\n                <option value=\"+40\">🇷🇴 +40 Romania</option>\n                <option value=\"+378\">🇸🇲 +378 San Marino</option>\n                <option value=\"+381\">🇷🇸 +381 Serbia</option>\n                <option value=\"+421\">🇸🇰 +421 Slovakia</option>\n                <option value=\"+386\">🇸🇮 +386 Slovenia</option>\n                <option value=\"+27\">🇿🇦 +27 South Africa</option>\n                <option value=\"+82\">🇰🇷 +82 South Korea</option>\n                <option value=\"+34\">🇪🇸 +34 Spain</option>\n                <option value=\"+46\">🇸🇪 +46 Sweden</option>\n                <option value=\"+41\">🇨🇭 +41 Switzerland</option>\n                <option value=\"+886\">🇹🇼 +886 Taiwan</option>\n                <option value=\"+44\">🇬🇧 +44 United Kingdom</option>\n              </select>\n              <input type=\"tel\" id=\"ea-phone\" placeholder=\"Mobile number\" class=\"cta-input cta-phone-input\" required pattern=\"[0-9\\s\\-]{6,15}\" autocomplete=\"tel\" />\n            </div>\n          </div>\n        </div>\n        <button type=\"submit\" class=\"btn-primary cta-submit-btn\">Get Early Access</button>\n      </form>\n      <div class=\"cta-success\" id=\"earlyAccessSuccess\" style=\"display:none;\">\n        <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\"><circle cx=\"10\" cy=\"10\" r=\"9\" stroke=\"#4ADE80\" stroke-width=\"1.5\"/><path d=\"M6 10l3 3 5-5\" stroke=\"#4ADE80\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        You're on the list! We'll be in touch soon.\n      </div>\n      <p class=\"cta-note\">Join 200+ music professionals already on the list.</p>\n    </div>\n  </section>\n\n  <!-- FOOTER -->\n  <footer class=\"footer\">\n    <div class=\"footer-inner\">\n      <div class=\"footer-logo\">\n        <img src=\"assets/Moshly-Main-Logo-1.svg\" alt=\"Moshly\" class=\"footer-logo-img\" />\n        <span>Moshly.io</span>\n      </div>\n      <p class=\"footer-tagline\">Micro-tools for the music industry.</p>\n      <div class=\"footer-links\">\n        <a href=\"privacy.html\">Privacy</a>\n        <a href=\"terms.html\">Terms</a>\n        <a href=\"pricing.html\">Pricing</a>\n        <a href=\"contact.html\">Contact</a>\n      </div>\n      <p class=\"footer-copy\">© 2026 Moshly. All rights reserved.</p>\n      <div class=\"theme-toggle\" id=\"themeToggle\" onclick=\"toggleTheme()\" aria-label=\"Toggle light/dark mode\" role=\"button\" tabindex=\"0\">\n        <span class=\"theme-toggle-icon theme-toggle-icon--sun\">\n          <svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\"><circle cx=\"9\" cy=\"9\" r=\"3.5\" fill=\"currentColor\"/><path d=\"M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M3.22 14.78l1.42-1.42M13.36 4.64l1.42-1.42\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n        </span>\n        <span class=\"theme-toggle-icon theme-toggle-icon--moon\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M13.5 10.5A6 6 0 0 1 5.5 2.5a6 6 0 1 0 8 8z\" fill=\"currentColor\"/></svg>\n        </span>\n      </div>\n    </div>\n  </footer>\n\n  <!-- AUTH MODAL REMOVED — see /login.html /signup.html /join.html -->\n  <div style=\"display:none\" aria-hidden=\"true\">\n    <div>\n\n      <!-- Close -->\n      <button class=\"auth-close\" onclick=\"closeModal()\" aria-label=\"Close\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\" fill=\"none\"><path d=\"M4 4l10 10M14 4L4 14\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/></svg>\n      </button>\n\n      <!-- Logo -->\n      <div class=\"auth-logo\">\n        <img src=\"assets/Moshly-Main-Logo-1.svg\" alt=\"Moshly\" class=\"auth-logo-img\" />\n        <span>Moshly</span>\n      </div>\n\n      <!-- Tabs -->\n      <div class=\"auth-tabs\">\n        <button class=\"auth-tab auth-tab--active\" id=\"tabLogin\" onclick=\"switchTab('login')\">Log In</button>\n        <button class=\"auth-tab\" id=\"tabRegister\" onclick=\"switchTab('register')\">Sign Up</button>\n        <button class=\"auth-tab\" id=\"tabInsertCode\" onclick=\"switchTab('insertCode')\">Insert Code</button>\n      </div>\n\n      <!-- LOGIN PANEL -->\n      <div class=\"auth-panel\" id=\"panelLogin\">\n        <form class=\"auth-form\" autocomplete=\"on\" onsubmit=\"handleAuth(event,'login')\">\n          <div class=\"auth-field\">\n            <label class=\"auth-label\" for=\"login-email\">Email</label>\n            <input class=\"auth-input\" type=\"email\" id=\"login-email\" placeholder=\"your@email.com\" required autocomplete=\"username\" />\n          </div>\n          <div id=\"login-feedback\" style=\"display:none;margin-bottom:12px;padding:10px 14px;border-radius:8px;background:rgba(248,113,113,.12);border:1px solid rgba(248,113,113,.3);font-size:.85rem;color:#f87171;\"></div>\n          <div class=\"auth-field\">\n            <div class=\"auth-label-row\">\n              <label class=\"auth-label\" for=\"login-password\">Password</label>\n              <a href=\"#\" class=\"auth-forgot\" onclick=\"switchTab('forgot');return false;\">Forgot password?</a>\n            </div>\n            <div class=\"auth-pw-wrap\">\n              <input class=\"auth-input\" type=\"password\" id=\"login-password\" data-pw=\"1\" placeholder=\"••••••••\" required autocomplete=\"current-password\" />\n              <button type=\"button\" class=\"auth-pw-toggle\" aria-label=\"Show password\" onclick=\"togglePwVisibility(this)\">\n                <svg class=\"pw-eye\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>\n                <svg class=\"pw-eye-off\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"display:none\"><path d=\"M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94\"/><path d=\"M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19\"/><line x1=\"1\" y1=\"1\" x2=\"23\" y2=\"23\"/></svg>\n              </button>\n            </div>\n          </div>\n          <button type=\"submit\" class=\"btn-primary auth-submit\">Log In</button>\n          <p class=\"auth-switch\">Don't have an account? <a href=\"#\" onclick=\"switchTab('register');return false;\">Sign Up</a></p>\n        </form>\n      </div>\n\n      <!-- REGISTER PANEL -->\n      <div class=\"auth-panel auth-panel--hidden\" id=\"panelRegister\">\n        <form class=\"auth-form\" onsubmit=\"handleAuth(event,'register')\">\n          <div id=\"reg-invite-banner\" style=\"display:none;margin-bottom:12px;padding:10px 14px;border-radius:8px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.3);font-size:.85rem;color:#a5b4fc;\"></div>\n          <div class=\"auth-form-row\">\n            <div class=\"auth-field\">\n              <label class=\"auth-label\" for=\"reg-fname\">First Name</label>\n              <input class=\"auth-input\" type=\"text\" id=\"reg-fname\" placeholder=\"First\" required autocomplete=\"given-name\" />\n            </div>\n            <div class=\"auth-field\">\n              <label class=\"auth-label\" for=\"reg-lname\">Last Name</label>\n              <input class=\"auth-input\" type=\"text\" id=\"reg-lname\" placeholder=\"Last\" required autocomplete=\"family-name\" />\n            </div>\n          </div>\n          <div class=\"auth-field\">\n            <label class=\"auth-label\" for=\"reg-email\">Email</label>\n            <input class=\"auth-input\" type=\"email\" id=\"reg-email\" placeholder=\"your@email.com\" required autocomplete=\"email\" />\n            <div id=\"reg-email-hint\" style=\"display:none;margin-top:5px;font-size:.78rem;color:#a5b4fc;\">📎 Email bound to this invite — cannot be changed.</div>\n          </div>\n          <div class=\"auth-field\">\n            <label class=\"auth-label\" for=\"reg-phone\">Phone</label>\n            <div class=\"auth-phone-wrap\">\n              <select class=\"auth-dial\" id=\"reg-dial\" required>\n                <option value=\"\" disabled selected>Country</option>\n                <option value=\"+355\">🇦🇱 +355 Albania</option>\n                <option value=\"+376\">🇦🇩 +376 Andorra</option>\n                <option value=\"+54\">🇦🇷 +54 Argentina</option>\n                <option value=\"+61\">🇦🇺 +61 Australia</option>\n                <option value=\"+43\">🇦🇹 +43 Austria</option>\n                <option value=\"+32\">🇧🇪 +32 Belgium</option>\n                <option value=\"+55\">🇧🇷 +55 Brazil</option>\n                <option value=\"+1-CA\">🇨🇦 +1 Canada</option>\n                <option value=\"+56\">🇨🇱 +56 Chile</option>\n                <option value=\"+57\">🇨🇴 +57 Colombia</option>\n                <option value=\"+385\">🇭🇷 +385 Croatia</option>\n                <option value=\"+357\">🇨🇾 +357 Cyprus</option>\n                <option value=\"+420\">🇨🇿 +420 Czech Republic</option>\n                <option value=\"+45\">🇩🇰 +45 Denmark</option>\n                <option value=\"+372\">🇪🇪 +372 Estonia</option>\n                <option value=\"+358\">🇫🇮 +358 Finland</option>\n                <option value=\"+33\">🇫🇷 +33 France</option>\n                <option value=\"+49\">🇩🇪 +49 Germany</option>\n                <option value=\"+30\">🇬🇷 +30 Greece</option>\n                <option value=\"+36\">🇭🇺 +36 Hungary</option>\n                <option value=\"+354\">🇮🇸 +354 Iceland</option>\n                <option value=\"+353\">🇮🇪 +353 Ireland</option>\n                <option value=\"+39\">🇮🇹 +39 Italy</option>\n                <option value=\"+81\">🇯🇵 +81 Japan</option>\n                <option value=\"+371\">🇱🇻 +371 Latvia</option>\n                <option value=\"+423\">🇱🇮 +423 Liechtenstein</option>\n                <option value=\"+370\">🇱🇹 +370 Lithuania</option>\n                <option value=\"+352\">🇱🇺 +352 Luxembourg</option>\n                <option value=\"+356\">🇲🇹 +356 Malta</option>\n                <option value=\"+52\">🇲🇽 +52 Mexico</option>\n                <option value=\"+377\">🇲🇨 +377 Monaco</option>\n                <option value=\"+31\">🇳🇱 +31 Netherlands</option>\n                <option value=\"+64\">🇳🇿 +64 New Zealand</option>\n                <option value=\"+47\">🇳🇴 +47 Norway</option>\n                <option value=\"+48\">🇵🇱 +48 Poland</option>\n                <option value=\"+351\">🇵🇹 +351 Portugal</option>\n                <option value=\"+40\">🇷🇴 +40 Romania</option>\n                <option value=\"+378\">🇸🇲 +378 San Marino</option>\n                <option value=\"+381\">🇷🇸 +381 Serbia</option>\n                <option value=\"+421\">🇸🇰 +421 Slovakia</option>\n                <option value=\"+386\">🇸🇮 +386 Slovenia</option>\n                <option value=\"+27\">🇿🇦 +27 South Africa</option>\n                <option value=\"+82\">🇰🇷 +82 South Korea</option>\n                <option value=\"+34\">🇪🇸 +34 Spain</option>\n                <option value=\"+46\">🇸🇪 +46 Sweden</option>\n                <option value=\"+41\">🇨🇭 +41 Switzerland</option>\n                <option value=\"+886\">🇹🇼 +886 Taiwan</option>\n                <option value=\"+44\">🇬🇧 +44 United Kingdom</option>\n              </select>\n              <input class=\"auth-input\" type=\"tel\" id=\"reg-phone\" placeholder=\"Mobile number\" required pattern=\"[0-9\\s\\-]{6,15}\" autocomplete=\"tel\" />\n            </div>\n          </div>\n          <div class=\"auth-field\">\n            <label class=\"auth-label\" for=\"reg-password\">Password</label>\n            <div class=\"auth-pw-wrap\">\n              <input class=\"auth-input\" type=\"password\" id=\"reg-password\" data-pw=\"1\" placeholder=\"Min. 8 characters\" required minlength=\"8\" autocomplete=\"new-password\" />\n              <button type=\"button\" class=\"auth-pw-toggle\" aria-label=\"Show password\" onclick=\"togglePwVisibility(this)\">\n                <svg class=\"pw-eye\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>\n                <svg class=\"pw-eye-off\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"display:none\"><path d=\"M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94\"/><path d=\"M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19\"/><line x1=\"1\" y1=\"1\" x2=\"23\" y2=\"23\"/></svg>\n              </button>\n            </div>\n          </div>\n          <div id=\"invite-code-field\" style=\"display:none;\">\n            <div class=\"auth-field\">\n              <label class=\"auth-label\" for=\"reg-invite-code\">Invite Code</label>\n              <input class=\"auth-input\" type=\"text\" id=\"reg-invite-code\" placeholder=\"MOSH-XXXX\" autocomplete=\"off\" style=\"text-transform:uppercase;letter-spacing:.1em;\" oninput=\"this.value=this.value.toUpperCase()\" />\n            </div>\n          </div>\n          <div class=\"auth-field\" style=\"margin-top:6px;\">\n            <label class=\"auth-consent-label\">\n              <input type=\"checkbox\" id=\"reg-terms\" class=\"auth-consent-check\" required />\n              <span>I agree to the <a href=\"/terms.html\" target=\"_blank\" style=\"color:var(--color-accent-primary);text-decoration:underline;\">Terms of Service</a> and <a href=\"/privacy.html\" target=\"_blank\" style=\"color:var(--color-accent-primary);text-decoration:underline;\">Privacy Policy</a>.</span>\n            </label>\n          </div>\n          <div class=\"auth-field\" style=\"margin-top:6px;\">\n            <label class=\"auth-consent-label\">\n              <input type=\"checkbox\" id=\"reg-marketing\" class=\"auth-consent-check\" />\n              <span>I'd like to receive Moshly updates, early access news, and feature announcements by email.</span>\n            </label>\n          </div>\n          <button type=\"submit\" class=\"btn-primary auth-submit\">Create Account</button>\n          <p class=\"auth-switch\">Already have an account? <a href=\"#\" onclick=\"switchTab('login');return false;\">Log In</a></p>\n        </form>\n      </div>\n\n      <!-- INSERT CODE PANEL -->\n      <div class=\"auth-panel auth-panel--hidden\" id=\"panelInsertCode\">\n        <div class=\"auth-forgot-header\">\n          <h3 class=\"auth-panel-title\">Join a Workspace</h3>\n          <p class=\"auth-panel-desc\">Enter the invite code shared by a workspace owner.</p>\n        </div>\n        <div id=\"insert-code-banner\" style=\"display:none;margin-bottom:12px;padding:10px 14px;border-radius:8px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.3);font-size:.85rem;color:#a5b4fc;\"></div>\n        <div class=\"auth-field\">\n          <label class=\"auth-label\" for=\"insert-code-input\">Invite Code</label>\n          <input class=\"auth-input\" type=\"text\" id=\"insert-code-input\" placeholder=\"MOSH-BXXXX\" autocomplete=\"off\"\n            style=\"text-transform:uppercase;letter-spacing:.1em;\"\n            oninput=\"this.value=this.value.toUpperCase()\" />\n        </div>\n        <div id=\"insert-code-feedback\" style=\"display:none;margin-top:6px;font-size:.82rem;\"></div>\n        <button type=\"button\" class=\"btn-primary auth-submit\" onclick=\"handleInsertCode()\" style=\"margin-top:12px;\">Continue</button>\n        <p class=\"auth-switch\">Already have an account? <a href=\"#\" onclick=\"switchTab('login');return false;\">Log In</a></p>\n      </div>\n\n      <!-- FORGOT PASSWORD PANEL -->\n      <div class=\"auth-panel auth-panel--hidden\" id=\"panelForgot\">\n        <div class=\"auth-forgot-header\">\n          <button class=\"auth-back\" onclick=\"switchTab('login')\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M10 3L5 8l5 5\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n            Back to Log In\n          </button>\n          <h3 class=\"auth-panel-title\">Reset your password</h3>\n          <p class=\"auth-panel-desc\">Enter your email and we'll send you a reset link.</p>\n        </div>\n        <form class=\"auth-form\" onsubmit=\"handleAuth(event,'forgot')\">\n          <div class=\"auth-field\">\n            <label class=\"auth-label\" for=\"forgot-email\">Email</label>\n            <input class=\"auth-input\" type=\"email\" id=\"forgot-email\" placeholder=\"your@email.com\" required autocomplete=\"email\" />\n          </div>\n          <div id=\"forgot-feedback\" class=\"auth-feedback error\" style=\"display:none; margin-bottom: 12px; font-size: 0.85rem;\"></div>\n          <button type=\"submit\" class=\"btn-primary auth-submit\">Send Reset Link</button>\n        </form>\n        <div class=\"auth-success\" id=\"forgotSuccess\" style=\"display:none;\">\n          <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\"><circle cx=\"10\" cy=\"10\" r=\"9\" stroke=\"#4ADE80\" stroke-width=\"1.5\"/><path d=\"M6 10l3 3 5-5\" stroke=\"#4ADE80\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n          Check your inbox — reset link sent!\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <script src=\"auth-client.js\"></script>\n  <script src=\"moshly-ui.js\"></script>\n  <script>\n    // Handle URL params that previously opened the modal — now redirect to dedicated pages\n    (function() {\n      const p = new URLSearchParams(location.search);\n      const collabInvite = p.get('collab_invite');\n      if (collabInvite) {\n        window.location.replace('/join.html?code=' + encodeURIComponent(collabInvite.toUpperCase()));\n      } else if (p.get('error') === 'hub_token_expired' && p.get('auth') === 'login') {\n        const cachedUser = (() => {\n          try { return JSON.parse(localStorage.getItem('moshly_user')); } catch { return null; }\n        })();\n        const redirect = p.get('redirect');\n        const retryKey = redirect ? `hubRetry:${redirect}` : null;\n        const retryCount = retryKey ? Number(sessionStorage.getItem(retryKey) || '0') : 0;\n\n        const canRetry =\n          cachedUser?.email &&\n          redirect &&\n          retryKey &&\n          retryCount < 3 &&\n          (() => {\n            try {\n              const target = new URL(redirect);\n              const host = target.hostname || '';\n              return host.endsWith('moshly.io') || host.endsWith('pages.dev');\n            } catch { return false; }\n          })();\n\n        if (canRetry) {\n          try { sessionStorage.setItem(retryKey, String(retryCount + 1)); } catch {}\n          setTimeout(() => window.location.replace(redirect), 450);\n        } else {\n          if (retryKey) sessionStorage.removeItem(retryKey);\n          window.location.replace('/login.html' + (redirect ? '?redirect=' + encodeURIComponent(redirect) : ''));\n        }\n      } else if (p.get('auth') === 'login') {\n        window.location.replace('/login.html');\n      } else if (p.get('auth') === 'register') {\n        window.location.replace('/signup.html');\n      }\n    })();\n\n\n    function handleEarlyAccess(e) {\n      e.preventDefault();\n      const btn = e.target.querySelector('.cta-submit-btn');\n      const original = btn.textContent;\n      btn.textContent = 'Sending…';\n      btn.disabled = true;\n      setTimeout(() => {\n        e.target.style.display = 'none';\n        const success = document.getElementById('earlyAccessSuccess');\n        if (success) success.style.display = 'flex';\n      }, 900);\n    }\n  </script>\n</body>\n</html>\n"
